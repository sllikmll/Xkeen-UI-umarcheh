<Window x:Class="UnifiedUiWpfPreview.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Unified UI — WPF Full Parity Preview v0.2.0" Width="1320" Height="840" MinWidth="1080" MinHeight="680"
        Background="#050B1A" Foreground="#E7ECF8" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <Style TargetType="Button">
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="Background" Value="#101B33"/>
      <Setter Property="BorderBrush" Value="#24385A"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="10,7"/>
      <Setter Property="Margin" Value="3"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#1D3B63"/><Setter Property="BorderBrush" Value="#67E8F9"/></Trigger></Style.Triggers>
    </Style>
    <Style TargetType="TextBox">
      <Setter Property="Background" Value="#081625"/><Setter Property="Foreground" Value="#EAF2FF"/><Setter Property="BorderBrush" Value="#21405F"/><Setter Property="Padding" Value="8"/><Setter Property="Margin" Value="3"/>
    </Style>
  </Window.Resources>
  <DockPanel Margin="14">
    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
      <Button Click="Status_Click">Start/Status Mihomo</Button>
      <Button Click="Restart_Click">Restart Mihomo</Button>
      <Button Click="Stop_Click">Stop Mihomo</Button>
      <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#8DA8C8" Margin="12,0">Готово</TextBlock>
    </StackPanel>
    <TextBox DockPanel.Dock="Bottom" x:Name="OutputBox" Height="190" AcceptsReturn="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"/>
    <TabControl x:Name="MainTabs" Background="#071426" Foreground="#E7ECF8">
      <TabItem Header="Маршрутизация"><StackPanel Margin="12"><Button Click="Proxies_Click">Обновить selectors /proxies</Button><Button Click="Ping_Click">Ping DIRECT</Button><TextBlock Text="selector-list-and-tiles · per-node-ping · PUT /proxies/{group}" TextWrapping="Wrap"/></StackPanel></TabItem>
      <TabItem Header="Mihomo"><StackPanel Margin="12"><Button Click="Proxies_Click">Загрузить proxy-table</Button><TextBlock Text="proxy-table через live Mihomo /proxies"/></StackPanel></TabItem>
      <TabItem Header="Соединения"><StackPanel Margin="12"><Button Click="Connections_Click">Обновить connections-table</Button><TextBlock Text="connections-table через /connections"/></StackPanel></TabItem>
      <TabItem Header="Конфиг"><DockPanel Margin="12"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><Button Click="ReadConfig_Click">Открыть config.yaml</Button><Button Click="SaveConfig_Click">Сохранить config.yaml</Button></StackPanel><TextBox x:Name="ConfigBox" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" TextWrapping="NoWrap"/></DockPanel></TabItem>
      <TabItem Header="Подписки"><StackPanel Margin="12"><TextBox x:Name="SubNameBox" Text="subscription_1"/><TextBox x:Name="SubUrlBox" Text="https://example.com/sub"/><Button Click="AddSubscription_Click">Добавить subscription-manager</Button><TextBox x:Name="ImportBox" Height="160" AcceptsReturn="True" Text="# vless:// / wireguard:// / yaml proxy block"/><Button Click="AddImport_Click">Добавить static-proxy-import</Button></StackPanel></TabItem>
      <TabItem Header="Маршруты DNS"><StackPanel Margin="12"><TextBox x:Name="DomainBox" Height="130" AcceptsReturn="True" Text="youtube.com&#x0a;github.com&#x0a;openai.com"/><Button Click="Resolve_Click">Собрать адреса</Button><TextBlock Text="dns-routes-manual-resolver через Dns.GetHostAddresses"/></StackPanel></TabItem>
      <TabItem Header="Логи"><StackPanel Margin="12"><Button Click="Logs_Click">Прочитать logs-viewer</Button></StackPanel></TabItem>
      <TabItem Header="Настройки"><StackPanel Margin="12"><TextBlock x:Name="SettingsText" TextWrapping="Wrap"/></StackPanel></TabItem>
    </TabControl>
  </DockPanel>
</Window>
